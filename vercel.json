{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/search",       "destination": "/search.html" },
    { "source": "/contract",     "destination": "/contract.html" },
    { "source": "/vendors",      "destination": "/vendors.html" },
    { "source": "/board",        "destination": "/board.html" },
    { "source": "/high-priority","destination": "/high-priority.html" },
    { "source": "/tech-vendors", "destination": "/tech-vendors.html" },
    { "source": "/campaigns",    "destination": "/campaigns.html" },
    { "source": "/take-action",  "destination": "/take-action.html" },
    { "source": "/about",        "destination": "/about.html" },
    { "source": "/sources",      "destination": "/sources.html" }
  ]
}
